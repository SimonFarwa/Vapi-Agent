      "id": "65357282-d27e-47ba-9058-a92713fc7944", "name": "Respond Booking", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.5, "position": [1280, -496]
    },
    {
      "parameters": { "jsCode": "const crypto = require('crypto');\nconst secret = $env.HERMES_WEBHOOK_SECRET_VAPICALL;\nif (!secret) throw new Error('HERMES_WEBHOOK_SECRET_VAPICALL nicht gesetzt (env_file fehlt?)');\nconst src = $('Vapi Webhook').first().json.body || {};\nconst msg = src.message || {};\nconst sd = (msg.analysis || {}).structuredData || {};\nconst d = $input.first().json;\nconst payload = {\n  event_type: 'end-of-call-report',\n  summary: d.summary || '',\n  transcript: String(d.transcript || '').slice(0, 8000),\n  caller_name: d.callerName || 'Unbekannt',\n  caller_number: ((src.call || {}).customer || {}).number || '',\n  concern: sd.concern || '',\n  appointment_booked: d.appointmentBooked === true,\n  appointment_date: sd.appointmentDate || '',\n  sentiment: d.sentiment || ''\n};\nconst body = JSON.stringify(payload);\nconst ts = Math.floor(Date.now() / 1000).toString();\nconst sig = crypto.createHmac('sha256', secret).update(ts + '.' + body).digest('hex');\nreturn [{ json: { body, ts, sig } }];" },
      "id": "hermes-sign-report", "name": "Hermes Sign Report", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [672, 128]
