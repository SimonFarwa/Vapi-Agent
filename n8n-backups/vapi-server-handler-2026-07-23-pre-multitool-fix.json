    },
    {
      "parameters": { "jsCode": "const src = $('Vapi Webhook').first().json.body || {};\nconst tc = ((src.message || {}).toolCallList || [])[0] || {};\nconst args = (tc.function || {})['arguments'] || {};\nreturn [{ json: {\n  startTime: args.startTime || '',\n  endTime: args.endTime || '',\n  toolCallId: tc.id || ''\n} }];" },
      "id": "extract-slot-code", "name": "Extract Slot Params", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [720, -304]
    },
    {
      "parameters": { "jsCode": "const src = $('Vapi Webhook').first().json.body || {};\nconst tc = ((src.message || {}).toolCallList || [])[0] || {};\nconst args = (tc.function || {})['arguments'] || {};\nconst callerNum = ((src.call || {}).customer || {}).number || '';\nlet start = args.start || '';\nconst parsed = new Date(start);\nif (start && !isNaN(parsed.getTime())) start = parsed.toISOString();\nconst firstName = args.firstName || '';\nconst lastName = args.lastName || '';\nconst phone = args.phone || callerNum || '';\nconst placeholder = ['noreply@farpa.de', ''];\nconst email = (args.email && !placeholder.includes(String(args.email).toLowerCase().trim())) ? args.email : 'info@farpa.de';\nconst notes = args.notes || '';\nconst body = JSON.stringify({\n  eventTypeId: 6309012,\n  start: start,\n  attendee: { name: (firstName + ' ' + lastName).trim(), email: email, timeZone: 'Europe/Berlin', phoneNumber: phone },\n  metadata: { source: 'vapi-voice-agent', notes: String(notes) }\n});\nreturn [{ json: { start, firstName, lastName, email, phone, notes, toolCallId: tc.id || '', body } }];" },
      "id": "extract-booking-code", "name": "Extract Booking Params", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [720, -496]
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={{ {results: [{toolCallId: (($json.body.message.toolCallList || [])[0] || {}).id || '', result: 'Unbekanntes Tool.'}]} }}", "options": {} },
      "id": "1f412d69-5f47-4670-8d1e-3eb60bc3eaab", "name": "Respond Unknown Tool", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.5, "position": [720, 32]
    },
    {
      "id": "8f97030d-4ddb-48f3-b8dc-76b0aabcdf71", "name": "Map Booking Result", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1080, -496],
      "parameters": { "jsCode": "const toolCallId = $('Extract Booking Params').first().json.toolCallId || '';\nconst d = $input.first().json;\nlet result;\nif (d && d.error) {\n  const msg = JSON.stringify(d.error.message || d.error || '');\n  if (msg.includes('maximum number of active bookings')) {\n    result = 'FEHLER TECHNISCH: Buchungssystem blockiert. KEINEN weiteren Slot versuchen. Rueckruf durch Herrn Stengelmair anbieten.';\n  } else if (msg.includes('already has booking') || msg.includes('not available') || msg.includes('no_available')) {\n    result = 'Slot nicht mehr frei. Einen anderen Termin anbieten.';\n  } else {\n    result = 'FEHLER TECHNISCH: Buchung fehlgeschlagen. KEINEN weiteren Slot versuchen. Rueckruf durch Herrn Stengelmair anbieten.';\n  }\n} else {\n  const data = (d && d.data) || d || {};\n  const uid = data.uid || data.id || '';\n  const start = data.start || $('Extract Booking Params').first().json.start || '';\n  result = 'Termin gebucht: ' + start + (uid ? ' (Buchungs-ID ' + uid + ')' : '') + '. Dem Anrufer bestaetigen.';\n}\nreturn [{ json: { toolCallId: toolCallId, result: result } }];" }
